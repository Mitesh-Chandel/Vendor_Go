<!DOCTYPE html>
<html>
<head>
  <title>Admin Dashboard</title>
 
  <style>
    
    .full {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: #f5f5f5;
      margin: 0;
      padding: 0;
      color: #333;
    }

    h2, h3 {
      color: #27ae60;
      margin-bottom: 15px;
    }

    h2 {
      font-size: 32px;
    }

    h3 {
      font-size: 24px;
      margin-top: 30px;
    }

    p {
      font-size: 16px;
      color: #555;
      margin-bottom: 20px;
    }

    hr {
      border: none;
      border-top: 1px solid #ccc;
      margin: 30px 0;
    }

   
    .dashboard-container {
      max-width: 1200px;
      margin: 30px auto;
      padding: 0 20px;
    }

    
    .stats-container {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      margin-top: 20px;
    }

    .stat-card {
      flex: 1 1 200px;
      background: white;
      border-radius: 10px;
      padding: 25px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.1);
      text-align: center;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .stat-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .stat-card h3 {
      font-size: 20px;
      margin-bottom: 10px;
      color: #555;
    }

    .stat-card p {
      font-size: 28px;
      font-weight: bold;
      color: #27ae60;
    }

    /* Orders Section */
    .orders-container {
      margin-top: 20px;
    }

    .order-card {
      background: white;
      border-radius: 10px;
      padding: 15px 20px;
      margin-bottom: 15px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.05);
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .order-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

    .order-info {
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .order-info span {
      font-size: 14px;
      color: #555;
    }

    .order-status {
      padding: 6px 12px;
      border-radius: 20px;
      font-weight: bold;
      text-align: center;
      min-width: 100px;
      color: white;
    }

    .status-pending {
      background-color: #f39c12;
    }

    .status-completed {
      background-color: #27ae60;
    }

    .status-cancelled {
      background-color: #e74c3c;
    }

    /* Vendors Section */
    .vendors-container {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 15px;
      margin-top: 20px;
    }

    .vendor-card {
      background: white;
      border-left: 5px solid #3498db;
      padding: 20px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .vendor-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }

    .vendor-info {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .vendor-info span {
      font-size: 14px;
      color: #555;
    }

    .vendor-username {
      font-weight: bold;
      font-size: 16px;
      color: #2c3e50;
    }

    .vendor-status {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 15px;
      font-size: 12px;
      font-weight: bold;
      color: white;
      background-color: #27ae60;
    }

    .vendor-status.unverified {
      background-color: #f39c12;
    }
    
    @media (max-width: 768px) {
      .stats-container {
        flex-direction: column;
      }
      .order-card {
        flex-direction: column;
        align-items: flex-start;
      }
      .order-status {
        margin-top: 10px;
      }
    }
  </style>
</head>
 <%- include('../partials/navbar') %>
<body>
  <div class="full">
  <div class="dashboard-container">
    <h2>👑 Welcome Back, Supreme Admin</h2>
    <p>
      System Status: <strong>Fully Operational</strong> 🚀 <br>
      Total Power Level: <%= stats.totalVendors + stats.totalProducts + stats.totalOrders %>
    </p>
    <hr>

    <h3>Stats</h3>
<div class="stats-container">
  <div class="stat-card">
    <h3>Total Vendors</h3>
    <p><%= stats.totalVendors %></p>
  </div>
  
  <div class="stat-card">
    <h3>Total Products</h3>
    <p><%= stats.totalProducts %></p>
  </div>

  <div class="stat-card">
    <h3>Total Orders</h3>
    <p><%= stats.totalOrders %></p>
  </div>

  <div class="stat-card" style="border-top: 5px solid #27ae60;">
    <h3>Total Price Orders</h3>
    <p>₹ <%= stats.totalRevenue.toLocaleString() %></p>
  </div>
</div>

    <hr>
    <h3>📋 Vendors List</h3>
    <% if (vendors && vendors.length > 0) { %>
      <div class="vendors-container">
        <% vendors.forEach(vendor => { %>
          <div class="vendor-card">
            <div class="vendor-info">
              <span class="vendor-username">👤 <%= vendor.username %></span>
              <span><strong>Email:</strong> <%= vendor.email %></span>
              <span><strong>ID:</strong> #<%= vendor.id %></span>
              <span><strong>Status:</strong> 
                <span class="vendor-status <%= vendor.verified ? '' : 'unverified' %>">
                  <%= vendor.verified ? '✓ Verified' : '⚠ Unverified' %>
                </span>
              </span>
              <% if (vendor.created_at) { %>
                <span><strong>Joined:</strong> <%= new Date(vendor.created_at).toLocaleDateString() %></span>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p style="color: #999;">No vendors found</p>
    <% } %>

    <hr>
    <h3>📦 Orders</h3>
    <% if (orders && orders.length > 0) { %>
      <div class="orders-container">
        <% orders.forEach(o => { %>
          <div class="order-card">
            <div class="order-info">
              <span style="font-weight: bold; font-size: 16px;">Order #<%= o.id %></span>
              <span><strong>Customer:</strong> <%= o.customerName %></span>
              <span><strong>Email:</strong> <%= o.customerEmail %></span>
              <span><strong>Phone:</strong> <%= o.customerPhone %></span>
              
              <span style="margin-top: 8px; font-weight: bold;">📋 Order Items:</span>
              <% if (o.items && o.items.length > 0) { %>
                <ul style="margin: 8px 0 0 20px; color: #555;">
                  <% o.items.forEach(item => { %>
                    <li><%= item.productName %> (Qty: <%= item.quantity %>) - ₹<%= parseFloat(item.price).toFixed(2) %></li>
                  <% }) %>
                </ul>
              <% } else { %>
                <span style="color: #999;">No items</span>
              <% } %>
              
              <span style="margin-top: 8px;"><strong>Total:</strong> ₹<%= parseFloat(o.totalPrice).toFixed(2) %></span>
              <span><strong>Date:</strong> <%= o.date ? new Date(o.date).toLocaleDateString() : 'N/A' %></span>
            </div>
            
            <div class="order-status 
              <%= (o.status && o.status.toLowerCase() === 'waiting') ? 'status-pending' : '' %>
              <%= (o.status && o.status.toLowerCase() === 'accepted') ? 'status-completed' : '' %>
              <%= (o.status && o.status.toLowerCase() === 'rejected') ? 'status-cancelled' : '' %>">
              <%= o.status %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p style="color: #999;">No orders found</p>
    <% } %>
</div>

</body>


</html>
  <%- include('../partials/footer') %>
