<!DOCTYPE html>
<html>
<head>
  <div class="body1">
  <title>Vendor Dashboard</title>
  <link rel="stylesheet" href="/css/vendordash.css">
</head>
<body>
  <%- include('../partials/navbar') %>


  <div class="dash">
    
    <div class="dashboard-header">
      <h2>Vendor Dashboard</h2>
      <a href="/vendor/add-product" class="add-btn">+ Add Product</a>
    </div>

    
    <h2>Your Products</h2>
    <br>
    <br>

<div class="products">
  <% if (products.length === 0) { %>
    <p>No products added yet.</p>
  <% } %>

  <% products.forEach(product => { %>
    <div class="product-card">

      <img src="<%= product.image %>" width="120">

      <h3><%= product.name %></h3>

      <p><%= product.description %></p>

      <p>Category: <%= product.category %></p>

      <p>Price: ₹<%= product.price %></p>

    </div>
  <% }) %>
</div>

  
    <h3>New Order Requests</h3>

<% if (!orders || orders.length === 0) { %>
  <p>No new orders</p>
<% } %>

<% orders && orders.forEach(order => { %>
<div class="order-card">

  <div class="order-info">
    <p><strong>Customer:</strong> <%= order.customer_name %></p>
    <p><strong>Phone:</strong> <%= order.customer_phone %></p>

    <p><strong>Items:</strong></p>

    <ul>
      <li>
        <%= order.product_name %> (x<%= order.quantity %>)
      </li>
    </ul>

    <p><strong>Total:</strong> ₹<%= order.total_price %></p>
    <p><strong>Status:</strong> <%= order.status %></p>
  </div>

  <div class="order-actions">
  <form action="/vendor/accept/<%= order.order_item_id %>" method="POST">
  <button type="submit">Accept</button>
</form>

<form action="/vendor/reject/<%= order.order_item_id %>" method="POST">
  <button type="submit">Reject</button>
</form>
  </div>

</div>
  <hr>
<% }) %>

</body>
<script src="/socket.io/socket.io.js"></script>

<script>
const socket = io();

socket.on("newOrder", (order) => {

  alert("🔔 New Order #" + order.orderId);

  location.reload();

});
</script>
</div>
 
</html>
<%- include('../partials/footer') %>