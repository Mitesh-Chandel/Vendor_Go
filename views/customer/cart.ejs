<!DOCTYPE html>
<html>
<head>
    <title>Your Cart</title>
    <style>
        body {
            background: #f4f6f9;
            font-family: Arial, sans-serif;
        }

        .cart-container {
            max-width: 900px;
            margin: 50px auto;
            padding: 30px;
            background: white;
            box-shadow: 0 8px 25px rgba(0,0,0,0.08);
            border-radius: 12px;
        }

        h1 {
            margin-bottom: 25px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        th, td {
            padding: 15px;
            border-bottom: 1px solid #eee;
            text-align: center;
        }

        th {
            background: #f9f9f9;
        }

        .qty-controls {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
        }

        .qty-btn {
            background: #14532d;
            color: white;
            border: none;
            padding: 5px 10px;
            border-radius: 4px;
            cursor: pointer;
        }

        .qty-btn:hover {
            background: #0f3d21;
        }

        .remove-btn {
            background: #e74c3c;
            color: white;
            border: none;
            padding: 6px 10px;
            border-radius: 4px;
            cursor: pointer;
        }

        .remove-btn:hover {
            background: #c0392b;
        }

        .total-section {
            text-align: right;
            font-size: 1.3rem;
            font-weight: bold;
            color: #14532d;
            margin-top: 20px;
        }

        .checkout-form {
            background: #f9f9f9;
            padding: 20px;
            border-radius: 8px;
            margin-top: 25px;
        }

        .checkout-form input {
            display: block;
            width: 100%;
            padding: 12px;
            margin: 12px 0;
            border: 1px solid #ccc;
            border-radius: 6px;
            box-sizing: border-box;
        }

        .btn-order {
            background: #14532d;
            color: white;
            border: none;
            padding: 14px;
            width: 100%;
            border-radius: 6px;
            cursor: pointer;
            font-size: 1rem;
        }

        .btn-order:hover {
            background: #0f3d21;
        }

        .empty-cart {
            text-align: center;
            padding: 40px;
        }

        .empty-cart a {
            color: #14532d;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <%- include('../partials/navbar') %>

    <div class="cart-container">
        <h1>🛒 Your Shopping Cart</h1>

        <% if (cart.length === 0) { %>
            <div class="empty-cart">
                <p>Your cart is empty.</p>
                <a href="/customer/shop">Go Shopping →</a>
            </div>
        <% } else { %>

            <table>
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Subtotal</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% cart.forEach(item => { %>
                        <tr>
                            <td><%= item.name %></td>
                            <td>₹<%= item.price %></td>

                            <td>
                                <div class="qty-controls">
                                    <!-- Decrease -->
                                    <form action="/customer/decrease-quantity" method="POST">
                                        <input type="hidden" name="productId" value="<%= item.id %>">
                                        <button type="submit" class="qty-btn">−</button>
                                    </form>

                                    <strong><%= item.quantity %></strong>

                                    <!-- Increase -->
                                    <form action="/customer/increase-quantity" method="POST">
                                        <input type="hidden" name="productId" value="<%= item.id %>">
                                        <button type="submit" class="qty-btn">+</button>
                                    </form>
                                </div>
                            </td>

                            <td>₹<%= item.price * item.quantity %></td>

                            <td>
                                <form action="/customer/remove-item" method="POST">
                                    <input type="hidden" name="productId" value="<%= item.id %>">
                                    <button type="submit" class="remove-btn">Remove</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>

            <div class="total-section">
                Grand Total: ₹<%= total %>
            </div>

            <div class="checkout-form">
                <h3>Finalize Your Order</h3>
                <form action="/customer/place-order" method="POST">
                    <input type="text" name="customerName" placeholder="Enter Full Name" required>
                    <input type="tel" name="customerPhone" placeholder="Mobile Number" required>
                    <button type="submit" class="btn-order">
                        Confirm Order (₹<%= total %>)
                    </button>
                </form>
            </div>

        <% } %>
    </div>

    <%- include('../partials/footer') %>

</body>
</html>