<!DOCTYPE html>
<html>
<head>
  <title>Customer Shop</title>
  <style>
   
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: #f5f5f5;
      margin: 0;
      padding: 0;
      color: #333;
    }

    a {
      text-decoration: none;
      color: #27ae60;
      font-weight: bold;
    }

    
    .shop-container {
      max-width: 1200px;
      margin: 30px auto;
      padding: 0 20px;
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      justify-content: center;
    }

    .product-card {
      background: white;
      border-radius: 10px;
      padding: 20px;
      width: 280px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.1);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      cursor: pointer;
    }

    .product-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }

    .product-card h3 {
      margin-top: 0;
      color: #27ae60;
      cursor: pointer;
      transition: color 0.3s ease;
    }

    .product-card a:hover h3 {
      color: #1e8449;
    }

    .product-card p {
      margin: 5px 0 15px;
      font-size: 16px;
    }

 
    .product-card form {
      display: flex;
      flex-direction: column;
    }

    .product-card input[type="text"],
    .product-card input[type="tel"],
    .product-card input[type="number"] {
      padding: 8px;
      margin: 5px 0 10px;
      border: 1px solid #ccc;
      border-radius: 5px;
      font-size: 14px;
    }

    .product-card input[type="number"] {
      width: 70px;
    }

    .product-card button {
      padding: 10px;
      background-color: #27ae60;
      color: white;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      font-weight: bold;
      transition: background-color 0.3s ease;
    }

    .product-card button:hover {
      background-color: #219150;
    }

    
    .no-products {
      text-align: center;
      font-size: 18px;
      margin: 50px 0;
      color: #555;
    }

   
    @media (max-width: 768px) {
      .shop-container {
        flex-direction: column;
        align-items: center;
      }

      .product-card {
        width: 90%;
      }
    }
    .product-img {
  width: 100%;
  height: 180px;     
  object-fit: cover;  
  border-radius: 8px;
  margin-bottom: 15px;
  cursor: pointer;
  transition: transform 0.3s ease, filter 0.3s ease;
}

    .product-card a:hover .product-img {
      transform: scale(1.05);
      filter: brightness(1.1);
    }

    .vendor-info {
      background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
      padding: 12px;
      border-radius: 8px;
      margin: 12px 0;
      border-left: 4px solid #27ae60;
      transition: background 0.3s ease, border-left-color 0.3s ease;
    }

    .product-card a:hover .vendor-info {
      background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
    }

    .vendor-info h4 {
      margin: 0 0 8px 0;
      color: #27ae60;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .vendor-name {
      font-size: 16px;
      font-weight: bold;
      color: #333;
      margin: 5px 0;
    }

    .vendor-email {
      font-size: 12px;
      color: #666;
      margin: 5px 0;
    }

    .vendor-badge {
      display: inline-block;
      background: #27ae60;
      color: white;
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 11px;
      margin-top: 8px;
      font-weight: bold;
    }
  </style>
</head>
<body>
  <%- include('../partials/navbar') %>

  <h1 style="text-align:center; margin-top:30px; color:#27ae60;">Customer Shop</h1>

  <% if (products.length === 0) { %>
    <p class="no-products">No products available. Ask vendor to add products.</p>
  <% } %>

  <div class="shop-container">

  <% products.forEach(function(product) { %>

  <div class="product-card">

    <a href="/customer/product/<%= product.id %>" style="text-decoration: none; color: inherit;">

      <h3><%= product.name %></h3>

      <img src="<%= product.image %>" alt="<%= product.name %>" class="product-img">

      <p>Price: ₹<%= product.price %></p>

      <% if (product.vendor) { %>
        <div class="vendor-info">
          <h4>📍 Sold By</h4>

          <div class="vendor-name"><%= product.vendor %></div>

          <div class="vendor-email"><%= product.vendor_email %></div>

          <span class="vendor-badge">✓ Verified Vendor</span>
        </div>
      <% } %>

    </a>

  

   <form action="/customer/add-to-cart" method="POST">
  <input type="hidden" name="productId" value="<%= product.vendor_product_id %>">

  <label for="qty-<%= product.vendor_product_id %>" style="font-size: 12px; color: #666;">Quantity:</label>

  <input 
    type="number"
    id="qty-<%= product.vendor_product_id %>"
    name="quantity"
    value="1"
    min="1"
    required
  >

  <button type="submit" style="background-color: #f39c12;">
    Add to Cart
  </button>
</form>
    </div>

    <% }); %>
  </div>
  

  <%- include('../partials/footer') %>
</body>
</html>
