<!DOCTYPE html>
<html>
<head>
  <title>Customer Shop</title>
  <style>

body{
  font-family: 'Segoe UI', sans-serif;
  background:#f4f6f9;
  margin:0;
}

/* TITLE */

h1{
  text-align:center;
  margin-top:30px;
  color:#27ae60;
}

/* SHOP GRID */

.shop-container{
  max-width:1200px;
  margin:30px auto;
  padding:0 20px;
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:25px;
}

/* CARD */

.product-card{
  background:white;
  border-radius:12px;
  padding:18px;
  box-shadow:0 8px 18px rgba(0,0,0,0.08);
  transition:all .3s ease;
}

.product-card:hover{
  transform:translateY(-6px);
  box-shadow:0 12px 24px rgba(0,0,0,0.15);
}

/* IMAGE */

.product-img{
  width:100%;
  height:180px;
  object-fit:cover;
  border-radius:8px;
  margin:10px 0;
  transition:.3s;
}

.product-card:hover .product-img{
  transform:scale(1.04);
}

/* PRODUCT NAME */

.product-card h3{
  margin:0;
  font-size:20px;
  color:#2c3e50;
}

/* PRICE */

.price{
  font-size:18px;
  font-weight:bold;
  color:#27ae60;
  margin-bottom:10px;
}

/* VENDOR BOX */

.vendor-info{
  background:#f8f9fa;
  padding:10px;
  border-radius:6px;
  border-left:4px solid #27ae60;
  margin:10px 0;
}

.vendor-name{
  font-weight:bold;
  font-size:15px;
}

.vendor-email{
  font-size:12px;
  color:#777;
}

/* QUANTITY INPUT */

input[type="number"]{
  padding:6px;
  width:70px;
  border:1px solid #ccc;
  border-radius:4px;
}

/* BUTTON */

button{
  margin-top:8px;
  padding:10px;
  border:none;
  border-radius:6px;
  background:#f39c12;
  color:white;
  font-weight:bold;
  cursor:pointer;
  transition:.3s;
}

button:hover{
  background:#d68910;
}

/* NO PRODUCTS */

.no-products{
  text-align:center;
  font-size:18px;
  color:#555;
  margin-top:40px;
}

</style>
</head>
<body>
  <%- include('../partials/navbar') %>

  <h1 style="text-align:center; margin-top:30px; color:#27ae60;">Customer Shop</h1>

  <% if (products.length === 0) { %>
    <p class="no-products">No products available. Ask vendor to add products.</p>
  <% } %>

  <div class="shop-container">

  <% products.forEach(function(product) { %>

  <div class="product-card">

    <a href="/customer/product/<%= product.id %>" style="text-decoration: none; color: inherit;">

      <h3><%= product.name %></h3>

      <img src="<%= product.image %>" alt="<%= product.name %>" class="product-img">

      <p>Price: ₹<%= product.price %></p>

      <% if (product.vendor) { %>
        <div class="vendor-info">
          <h4>📍 Sold By</h4>

          <div class="vendor-name"><%= product.vendor %></div>

          <div class="vendor-email"><%= product.vendor_email %></div>

          <span class="vendor-badge">✓ Verified Vendor</span>
        </div>
      <% } %>

    </a>

  

  <form action="/customer/add-to-cart" method="POST">

  <input type="hidden" name="vendorProductId" value="<%= product.vendor_product_id %>">

  <label for="qty-<%= product.vendor_product_id %>" style="font-size:12px;color:#666;">
    Quantity:
  </label>

  <input 
    type="number"
    id="qty-<%= product.vendor_product_id %>"
    name="quantity"
    value="1"
    min="1"
    required
  >

  <button type="submit">
    Add to Cart
  </button>

</form>
    </div>

    <% }); %>
  </div>
  

  <%- include('../partials/footer') %>
</body>
</html>
