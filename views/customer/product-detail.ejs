<!DOCTYPE html>
<html>
<head>
  <title><%= product.name %> - Vendor Go</title>
  <style>
.product-detail-container {
  max-width: 1100px;
  margin: 30px auto;
  padding: 20px;
  font-family: Arial, sans-serif;
}

.back-button {
  display: inline-block;
  margin-bottom: 15px;
  color: #27ae60;
  text-decoration: none;
  font-weight: bold;
}

.breadcrumb {
  margin-bottom: 20px;
  font-size: 14px;
  color: #555;
}

.breadcrumb-category {
  color: #27ae60;
  font-weight: bold;
}

.product-main {
  display: flex;
  gap: 40px;
}

.product-image img {
  max-width: 350px;
  border-radius: 8px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.1);
}

.product-info {
  flex: 1;
}

.product-category {
  font-size: 14px;
  color: #777;
  margin-bottom: 5px;
}

.product-info h1 {
  margin: 5px 0 15px;
  font-size: 28px;
  color: #333;
}

.product-description {
  margin-bottom: 20px;
  line-height: 1.6;
  color: #555;
}

.product-price {
  font-size: 22px;
  font-weight: bold;
  color: #27ae60;
  margin-bottom: 20px;
}

.cart-form {
  margin-bottom: 30px;
}

.quantity-selector {
  display: flex;
  align-items: center;
  margin-bottom: 15px;
}

.quantity-selector button {
  background: #eee;
  border: 1px solid #ccc;
  padding: 6px 12px;
  cursor: pointer;
  font-size: 16px;
}

.quantity-selector input {
  width: 50px;
  text-align: center;
  border: 1px solid #ccc;
  margin: 0 8px;
  font-size: 16px;
}

.add-to-cart-btn {
  background: #27ae60;
  color: #fff;
  border: none;
  padding: 10px 18px;
  font-size: 16px;
  cursor: pointer;
  border-radius: 4px;
  transition: background 0.3s;
}

.add-to-cart-btn:hover {
  background: #219150;
}

.vendor-section {
  margin-top: 20px;
}

.vendor-details {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f9f9f9;
  padding: 12px;
  border-radius: 6px;
  border: 1px solid #ddd;
}

.vendor-name {
  font-weight: bold;
  color: #333;
}

.vendor-email {
  font-size: 14px;
  color: #777;
}

.vendor-badge {
  color: #27ae60;
  font-weight: bold;
}

.other-vendors {
  margin-top: 25px;
}

.vendor-card-link {
  text-decoration: none;
  color: inherit;
}

.vendor-card {
  display: flex;
  justify-content: space-between;
  padding: 12px;
  margin-bottom: 10px;
  border: 1px solid #ddd;
  border-radius: 6px;
  background: #fff;
  transition: box-shadow 0.2s;
}

.vendor-card:hover {
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.vendor-email-small {
  font-size: 13px;
  color: #777;
}

.vendor-card-price {
  font-weight: bold;
  color: #27ae60;
}
</style>
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="product-detail-container">
    <a href="/customer/shop" class="back-button">Back to Shop</a>

    <div class="breadcrumb">
      <a href="/customer/shop">Shop</a> / 
      <span style="color: #27ae60;"><%= product.category %></span>
    </div>

    <div class="product-main">
      <div class="product-image">
        <img src="<%= product.image %>" alt="<%= product.name %>">
      </div>

      <div class="product-info">
        <div class="product-category"><%= product.category %></div>
        <h1><%= product.name %></h1>

        <p class="product-description">
          <% if (product.description) { %>
            <%= product.description %>
          <% } else { %>
            No description available
          <% } %>
        </p>

        <div class="product-price">₹<%= product.price %></div>
        <form action="/customer/add-to-cart" method="POST">
  <input type="hidden" name="vendorProductId" value="<%= product.vendor_product_id %>">

  <div class="quantity-selector">
    <button type="button" onclick="decreaseQty()">-</button>
    <input type="text" id="quantity" name="quantity" value="1" readonly>
    <button type="button" onclick="increaseQty()">+</button>
  </div>

  <button type="submit" class="add-to-cart-btn">Add to Cart</button>
</form>

        <!-- Vendor Information -->
        <% if (product.vendor_name) { %>
          <div class="vendor-section">
            <h2>Sold By</h2>

            <div class="vendor-details">
              <div class="vendor-info">
                <div class="vendor-name"><%= product.vendor_name %></div>
                <div class="vendor-email"><%= product.vendor_email %></div>
              </div>
              <span class="vendor-badge">✓ Verified</span>
            </div>
          </div>

          <!-- Other Vendors -->
          <div class="other-vendors">
            <h3>Other Vendors</h3>

            <% 
            const otherVendors = vendors.filter(v => v.vendor_product_id !== product.vendor_product_id);
            %>

            <% if (otherVendors.length > 0) { %>
              <% otherVendors.forEach(function(v) { %>
                <a href="/customer/vendor-product/<%= v.vendor_product_id %>" style="text-decoration:none;color:black">
                  <div class="vendor-card">
                    <div>
                      <b><%= v.vendor_name %></b><br>
                      <span style="font-size:13px;color:#777"><%= v.vendor_email %></span>
                    </div>
                    <div class="vendor-card-price">
                      ₹<%= v.price %>
                    </div>
                  </div>
                </a>
              <% }) %>
            <% } else { %>
              <p>No other vendors available</p>
            <% } %>
          </div>
        <% } %> <!-- Closing if(product.vendor_name) -->

      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script>
    function increaseQty() {
      const input = document.getElementById('quantity');
      input.value = parseInt(input.value) + 1;
    }

    function decreaseQty() {
      const input = document.getElementById('quantity');
      if (parseInt(input.value) > 1) {
        input.value = parseInt(input.value) - 1;
      }
    }
  </script>
</body> 
</html>
</html>
