<%- include('partials/navbar') %>

<style>
  :root {
    --primary: #27ae60;
    --primary-light: #dcfce7;
    --dark: #0f172a;
    --text-main: #334155;
    --text-muted: #64748b;
 
    --bg-body: #f1f5f9; 
    --card-bg: #ffffff;
    --border-soft: #e2e8f0;
  }

  body {
  font-family: 'Inter', -apple-system, sans-serif;
  margin: 0;
 
  background-color: #fdfaf5; 
  
 
  background-image: 
    linear-gradient(90deg, rgba(210, 180, 140, 0.05) 1px, transparent 1px),
    linear-gradient(rgba(210, 180, 140, 0.05) 1px, transparent 1px);
  background-size: 40px 40px;
  
  color: #2c3e50;
}

 
  .hero {
    padding: 120px 20px;
    position: relative;
  
    background: radial-gradient(circle at top right, #dcfce7 0%, transparent 40%),
                radial-gradient(circle at top left, #f1f5f9 0%, transparent 30%),
                white;
    text-align: center;
    border-bottom: 1px solid var(--border-soft);
  }

  .logo {
    width: 110px;
    height: 110px;
    border-radius: 24px;
    background: white;
    padding: 4px;
    border: 1px solid var(--border-soft);
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
  }

  .hero h1 {
    font-size: 3.8rem;
    font-weight: 800;
    color: var(--dark);
    letter-spacing: -0.05em;
    margin: 24px 0;
  }
.hero {
  padding: 120px 20px;
  position: relative;
  overflow: hidden;
  text-align: center;
  color: white;

  background-color: #fdf6ec ; 

  border-bottom: 1px solid #1f8a4d;
}

.hero h1,
.hero p {
  color: white;
}

.hero::after {
  content: "";
  position: absolute;
  top: -10%;
  right: -5%;
  width: 400px;
  height: 400px;
  background: rgba(39, 174, 96, 0.03);
  filter: blur(80px);
  border-radius: 50%;
  z-index: 0;
}

 
  .container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 80px 20px;
  }

  .stat-card {
    background: var(--card-bg);
    padding: 40px;
    border-radius: 20px;
    border: 1px solid var(--border-soft);
    text-align: center;
   
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease;
  }

  .stat-card:hover {
    transform: translateY(-5px);
    border-color: var(--primary);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
  }


  .accent-section {
    background-color: var(--dark);
    color: white;
    border-radius: 30px;
    padding: 60px;
    margin: 40px 0;
    text-align: center;
  }

  .btn {
    padding: 16px 32px;
    border-radius: 12px;
    font-size: 1.1rem;
    font-weight: 600;
    text-decoration: none;
    display: inline-block;
    transition: 0.2s;
  }

  .btn-primary {
    background: var(--primary);
    color: white;
  }

  .btn-primary:hover {
    background: var(--primary-hover);
    box-shadow: 0 0 20px rgba(39, 174, 96, 0.4);
  }

  .btn-secondary {
    background: rgba(255,255,255,0.1);
    color: white;
    border: 1px solid rgba(255,255,255,0.2);
    backdrop-filter: blur(5px);
  }

  @media (max-width: 768px) {
    .hero h1 { font-size: 2.8rem; }


  }

  .hero {
  color: #1e293b;
}

.hero h1 {
  font-size: 48px;
  font-weight: 700;
  color: #0f172a;
}

.hero p {
  font-size: 18px;
  color: #475569;
  margin-bottom: 30px;
}

.highlight {
  color: #14532d; 
}

.btn-primary {
  background: #14532d;
  color: white;
  border: none;
}

.btn-primary:hover {
  background: #0f3d21;
}

.btn-secondary {
  background: transparent;
  color: #14532d;
  border: 2px solid #14532d;
}

.btn-secondary:hover {
  background: #14532d;
  color: white;
}
</style>

<section class="hero">
  <img src="/uploads/logo.png" alt="Vendor Go" class="logo">
  <h1>Freshness from <br><span style="color: var(--primary);">Local Vendors</h1>
  <p>Your neighborhood marketplace for hand-picked, organic produce. Better for the Vendors,fresher for your family.</p>
  
  <div style="display: flex; justify-content: center; gap: 15px; flex-wrap: wrap;">
    <a href="/customer/shop" class="btn btn-primary"> Explore Shop</a>
    <a href="/vendor/login" class="btn btn-secondary" style="color: var(--dark); border-color: var(--border-soft);">🧑‍🌾 Vendor Portal</a>
  </div>
</section>

<div class="container">
  <div class="stats-grid">
    <div class="stat-card">
      <h2 style="color: var(--primary); font-size: 3rem; margin: 0;"><%= typeof vendors !== 'undefined' ? vendors.length : 20 %>+</h2>
      <p>Verified Vendors</p>
    </div>
    <div class="stat-card">
      <h2 style="color: var(--primary); font-size: 3rem; margin: 0;">100%</h2>
      <p>Organic Quality</p>
    </div>
    <div class="stat-card">
      <h2 style="color: var(--primary); font-size: 3rem; margin: 0;">Fast</h2>
      <p>Local Delivery</p>
    </div>
  </div>

  <div class="accent-section">
    <h2 style="font-size: 2.5rem; margin-bottom: 20px;">Cut the Middleman.</h2>
    <p style="color: #94a3b8; font-size: 1.2rem; max-width: 600px; margin: 0 auto 30px;">
      By shopping on Vendor Go, 95% of your money goes directly to the local Vendors.
      Help your community grow while eating better food.
    </p>
    <a href="/customer/shop" class="btn btn-primary">Get Started Now</a>
  </div>
</div>

